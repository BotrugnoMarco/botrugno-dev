---
import type { Lang } from '../i18n/ui'
import { useTranslations } from '../i18n/utils'

interface Props { lang: Lang }
const { lang } = Astro.props
const t = useTranslations(lang)

const isIT = lang === 'it'
const homeHref = isIT ? '/' : '/en/'

const experience = isIT ? [
  {
    period: `mar 2022 – ${t('cv.present')}`,
    role: 'Full-Stack Developer',
    company: 'BarbarHouse S.R.L.',
    location: 'Casarano (LE)',
    note: 'Mid-level · Front-end & Back-end',
  },
  {
    period: 'giu 2021 – set 2021',
    role: 'Maître',
    company: 'La Casarana Wellness Eco Resort',
    location: 'Presicce-Acquarica (LE)',
    note: 'Responsabile di Sala',
  },
  {
    period: 'giu 2020 – set 2020',
    role: 'Cameriere',
    company: 'La Casarana Wellness Eco Resort',
    location: 'Presicce-Acquarica (LE)',
    note: 'Vice-Maître',
  },
  {
    period: 'lug 2019 – set 2019',
    role: 'Cameriere',
    company: 'La Casarana Wellness Eco Resort',
    location: 'Presicce-Acquarica (LE)',
  },
  {
    period: 'gen 2019 – feb 2019',
    role: 'Tecnico informatico',
    company: 'Diemme Service',
    location: 'Casarano (LE)',
    note: 'Alternanza scuola-lavoro',
  },
  {
    period: 'feb 2018',
    role: 'Tecnico informatico',
    company: 'Ciemme Informatica',
    location: 'Presicce (LE)',
    note: 'Alternanza scuola-lavoro',
  },
] : [
  {
    period: `Mar 2022 – ${t('cv.present')}`,
    role: 'Full-Stack Developer',
    company: 'BarbarHouse S.R.L.',
    location: 'Casarano (LE)',
    note: 'Mid-level · Front-end & Back-end',
  },
  {
    period: 'Jun 2021 – Sep 2021',
    role: 'Maître',
    company: 'La Casarana Wellness Eco Resort',
    location: 'Presicce-Acquarica (LE)',
    note: 'Head Waiter / Floor Manager',
  },
  {
    period: 'Jun 2020 – Sep 2020',
    role: 'Waiter',
    company: 'La Casarana Wellness Eco Resort',
    location: 'Presicce-Acquarica (LE)',
    note: 'Assistant Head Waiter',
  },
  {
    period: 'Jul 2019 – Sep 2019',
    role: 'Waiter',
    company: 'La Casarana Wellness Eco Resort',
    location: 'Presicce-Acquarica (LE)',
  },
  {
    period: 'Jan 2019 – Feb 2019',
    role: 'IT Technician',
    company: 'Diemme Service',
    location: 'Casarano (LE)',
    note: 'School-work placement',
  },
  {
    period: 'Feb 2018',
    role: 'IT Technician',
    company: 'Ciemme Informatica',
    location: 'Presicce (LE)',
    note: 'School-work placement',
  },
]

const education = isIT ? [
  {
    period: `set 2020 – ${t('cv.present')}`,
    degree: 'Informatica e Tecnologie per la produzione del Software',
    institution: 'Università degli Studi di Bari Aldo Moro',
    location: 'Bari',
  },
  {
    period: 'set 2015 – giu 2020',
    degree: 'Diploma di Perito industriale in Informatica',
    institution: 'IIS "A. Meucci"',
    location: 'Casarano (LE)',
    note: 'Voto finale: 90/100',
  },
] : [
  {
    period: `Sep 2020 – ${t('cv.present')}`,
    degree: 'Computer Science and Software Production Technologies',
    institution: 'Università degli Studi di Bari Aldo Moro',
    location: 'Bari',
  },
  {
    period: 'Sep 2015 – Jun 2020',
    degree: 'Diploma in Industrial Computing',
    institution: 'IIS "A. Meucci"',
    location: 'Casarano (LE)',
    note: 'Final grade: 90/100',
  },
]

const certifications = [
  {
    year: '2019',
    title: 'Introduction to Cybersecurity',
    issuer: 'Cisco Networking Academy',
  },
  {
    year: '2018',
    title: 'Preliminary English Test (PET) – B1',
    issuer: 'Cambridge Assessment English',
  },
  {
    year: '2013',
    title: isIT ? "Giochi Matematici d'Autunno – 3° posto Cat. C1" : 'Autumn Mathematics Games – 3rd place Cat. C1',
    issuer: 'PRISTEM, Università Bocconi',
  },
]

const skills = [
  { category: 'Frontend', items: ['HTML/CSS', 'JavaScript', 'Vue 3', 'React', 'Nuxt.js', 'Astro', 'Ionic', 'Bootstrap'] },
  { category: 'Backend',  items: ['Node.js', 'Fastify', 'PHP', 'MySQL', 'Redis', 'Prisma', 'C/C++', 'Java', 'Yii'] },
  { category: 'Mobile',   items: ['Ionic', 'Capacitor', 'Firebase', 'Android'] },
  { category: 'Tools',    items: ['Git', 'Docker', 'Vite', 'Socket.io', 'LaTeX', 'Cisco Packet Tracer'] },
]

const languages = isIT ? [
  { lang: 'Italiano', level: 'Madrelingua' },
  { lang: 'Inglese',  level: 'B1 — PET' },
] : [
  { lang: 'Italian', level: 'Native' },
  { lang: 'English', level: 'B1 — PET' },
]

const hobbies = isIT
  ? ['Programmazione', 'Internet of Things', 'Cybersecurity', 'Grafica & Design', 'Psicoanalisi', 'Calcio', 'Pallavolo']
  : ['Programming', 'Internet of Things', 'Cybersecurity', 'Graphic Design', 'Psychoanalysis', 'Football', 'Volleyball']
---

<section style="max-width: 780px; margin: 0 auto; padding: 7rem 1.5rem 5rem;">

  <a href={homeHref} class="cv-back">{t('cv.back')}</a>

  <div class="cv-header fade-up">
    <div>
      <p class="section-label" style="margin-bottom: 0.5rem;">{t('nav.cv')}</p>
      <h1 style="font-family: 'Syne', sans-serif; font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.1;">
        Marco Luigi <span class="gradient-text">Botrugno</span>
      </h1>
    </div>
    <a href="/CV_Marco_Luigi_Botrugno.pdf" download class="btn-red cv-download">{t('cv.download')}</a>
  </div>

  <!-- Esperienza -->
  <div class="cv-section fade-up">
    <h2 class="cv-section-title">{t('cv.experience')}</h2>
    <div class="cv-timeline">
      {experience.map(item => (
        <div class="cv-item">
          <span class="cv-period">{item.period}</span>
          <div class="cv-dot"></div>
          <div class="cv-content">
            <p class="cv-role">{item.role}</p>
            <p class="cv-company">{item.company} · {item.location}</p>
            {item.note && <p class="cv-note">{item.note}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Formazione -->
  <div class="cv-section fade-up">
    <h2 class="cv-section-title">{t('cv.education')}</h2>
    <div class="cv-timeline">
      {education.map(item => (
        <div class="cv-item">
          <span class="cv-period">{item.period}</span>
          <div class="cv-dot"></div>
          <div class="cv-content">
            <p class="cv-role">{item.degree}</p>
            <p class="cv-company">{item.institution} · {item.location}</p>
            {item.note && <p class="cv-note">{item.note}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Certificazioni -->
  <div class="cv-section fade-up">
    <h2 class="cv-section-title">{t('cv.certifications')}</h2>
    <div class="cv-timeline">
      {certifications.map(item => (
        <div class="cv-item">
          <span class="cv-period">{item.year}</span>
          <div class="cv-dot"></div>
          <div class="cv-content">
            <p class="cv-role">{item.title}</p>
            <p class="cv-company">{item.issuer}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Competenze -->
  <div class="cv-section fade-up">
    <h2 class="cv-section-title">{t('cv.skills')}</h2>
    <div class="cv-skills-grid">
      {skills.map(group => (
        <div>
          <p class="cv-skills-category">{group.category}</p>
          <div class="cv-tags">
            {group.items.map(item => (
              <span class="badge badge-gray">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Lingue -->
  <div class="cv-section fade-up">
    <h2 class="cv-section-title">{t('cv.languages')}</h2>
    <div class="cv-langs">
      {languages.map(l => (
        <div class="cv-lang-item">
          <span class="cv-role" style="font-size: 0.95rem;">{l.lang}</span>
          <span class="cv-note" style="margin-top: 0;">{l.level}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Hobby -->
  <div class="cv-section fade-up">
    <h2 class="cv-section-title">{t('cv.hobbies')}</h2>
    <div class="cv-tags">
      {hobbies.map(h => (
        <span class="badge badge-gray">{h}</span>
      ))}
    </div>
  </div>

</section>

<style>
  .cv-back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 2.5rem;
    transition: color 0.2s;
  }
  .cv-back:hover { color: var(--text); }

  .cv-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 3.5rem;
    flex-wrap: wrap;
  }

  .cv-download {
    flex-shrink: 0;
    white-space: nowrap;
  }

  .cv-section {
    margin-bottom: 3rem;
  }

  .cv-section-title {
    font-family: 'Syne', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .cv-timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .cv-item {
    display: grid;
    grid-template-columns: 160px 1px 1fr;
    gap: 0 1.5rem;
    align-items: start;
    padding-bottom: 1.5rem;
    position: relative;
  }

  .cv-item:not(:last-child) .cv-dot::after {
    content: '';
    position: absolute;
    left: calc(160px + 1.5rem - 0.5px);
    top: 8px;
    bottom: 0;
    width: 1px;
    background: rgba(255,255,255,0.08);
  }

  .cv-period {
    font-size: 0.8rem;
    color: var(--muted);
    padding-top: 2px;
    line-height: 1.4;
  }

  .cv-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--red);
    margin-top: 4px;
    flex-shrink: 0;
    position: relative;
    justify-self: center;
  }

  .cv-content {
    padding-bottom: 0;
  }

  .cv-role {
    font-family: 'Syne', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .cv-company {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.4;
  }

  .cv-note {
    font-size: 0.8rem;
    color: var(--blue);
    margin-top: 0.2rem;
  }

  .cv-skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .cv-skills-category {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.6rem;
  }

  .cv-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .cv-langs {
    display: flex;
    gap: 3rem;
  }

  .cv-lang-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  @media (max-width: 600px) {
    .cv-skills-grid { grid-template-columns: 1fr; }
    .cv-langs { gap: 1.5rem; }
  }

  @media (max-width: 600px) {
    .cv-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
      padding-bottom: 1.75rem;
      padding-left: 1rem;
      border-left: 1px solid rgba(255,255,255,0.08);
    }
    .cv-item:not(:last-child) .cv-dot::after { display: none; }
    .cv-dot { display: none; }
    .cv-period { font-size: 0.75rem; color: var(--red); }
    .cv-header { flex-direction: column; align-items: flex-start; }
  }
</style>
