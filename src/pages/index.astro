---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/Hero.astro'
import About from '../components/About.astro'
import MatchReady from '../components/MatchReady.astro'
import Projects from '../components/Projects.astro'
import Contact from '../components/Contact.astro'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Marco Luigi Botrugno',
  url: 'https://botrugno.dev',
  jobTitle: 'Full-Stack Developer',
  nationality: 'Italian',
  sameAs: [
    'https://github.com/BotrugnoMarco',
    'https://www.linkedin.com/in/marco-luigi-botrugno-4332b21b7',
  ],
}
---

<Layout lang="it" schema={schema}>
  <Hero lang="it" />
  <About lang="it" />
  <MatchReady lang="it" />
  <Projects lang="it" />
  <Contact lang="it" />
</Layout>
